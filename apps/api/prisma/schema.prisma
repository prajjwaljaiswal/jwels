model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Order {
  id                String      @id @default(uuid())
  customerId        String
  customer          User        @relation(fields: [customerId], references: [id])
  totalAmount       Decimal     @db.Decimal(10, 2)
  shippingTotal     Decimal     @db.Decimal(10, 2) @default(0)
  status            OrderStatus @default(PENDING)
  paymentMethod     String      @default("RAZORPAY") // denormalized snapshot for historical orders
  paymentMethodId   String?
  paymentMethodRef  VendorPaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  shippingAddress   Json // { name, line1, line2, city, state, pincode, phone }
  razorpayOrderId   String?     @unique
  razorpayPaymentId String?

  // Coupon snapshot (one coupon per order)
  couponId       String?
  coupon         Coupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponCode     String?
  discountAmount Decimal @db.Decimal(10, 2) @default(0)

  // Gift wrap (optional upsell; fee resolved server-side from vendor block settings)
  giftWrap       Boolean @default(false)
  giftMessage    String?
  giftWrapFee    Decimal @db.Decimal(10, 2) @default(0)

  // Marketing attribution snapshot captured at checkout (survives later consent changes
  // and works for guest orders). Click ids feed server-side conversion uploads (§8).
  marketingConsent ConsentStatus @default(UNKNOWN)
  gclid            String?       // Google click id
  gbraid           String?       // Google app/web click id (iOS)
  wbraid           String?       // Google web click id (iOS)
  metaFbc          String?       // Meta click id cookie (_fbc)
  metaFbp          String?       // Meta browser id cookie (_fbp)

  // Idempotency: a client-supplied key dedupes retried checkout submissions.
  idempotencyKey String? @unique

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  items       OrderItem[]
  redemption  CouponRedemption?
  shipments   Shipment[]
  invoice     Invoice?
  returns     ReturnRequest[]
  disputes    Dispute[]
  conversionEvents ConversionEvent[]
  supportTickets   SupportTicket[]

  @@index([customerId])
  @@index([status])
  @@index([paymentMethodId])
  @@index([couponId])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id              String      @id @default(uuid())
  orderId         String
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product     @relation(fields: [productId], references: [id])
  vendorId        String
  vendor          Vendor      @relation(fields: [vendorId], references: [id])
  quantity        Int
  priceAtPurchase Decimal     @db.Decimal(10, 2)
  // status per-item lets one order have items shipped at different times
  status          OrderStatus @default(PAID)

  // Shipping snapshot — recorded at order time so historical orders survive method edits/deletes
  shippingMethodId String?
  shippingCarrier  String?
  shippingService  String?  // "Standard", "Express", carrier-defined service code, etc.
  shippingCost     Decimal? @db.Decimal(10, 2)
  trackingNumber   String?
  trackingUrl      String?
  labelUrl         String?
  waybillUrl       String?   // vendor-uploaded waybill / dispatch document
  dispatchedAt     DateTime? // stamped when status → SHIPPED
  deliveredAt      DateTime? // stamped when status → DELIVERED (auto or manual)

  // Variation snapshot at order time
  variationComboId String?
  variationCombo   ProductVariationCombo? @relation("OrderItemCombo", fields: [variationComboId], references: [id], onDelete: SetNull)
