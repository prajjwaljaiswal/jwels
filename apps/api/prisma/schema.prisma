model Review {
  id              String   @id @default(uuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId      String
  customer        User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rating          Int      // 1–5
  title           String?
  body            String?
  mediaUrls       String[] // Cloudinary URLs (images + videos)
  mediaTypes      String[] // "image" | "video" — parallel array to mediaUrls
