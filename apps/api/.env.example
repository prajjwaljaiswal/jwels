# Postgres connection string. In production use a pooled URL from Prisma Cloud /
# Supabase / Neon. In local dev, point at a docker-compose Postgres.
DATABASE_URL="postgresql://user:password@localhost:5432/jewel"

# JWT — sign auth tokens. Use 32+ random bytes (openssl rand -hex 32).
JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# Cloudinary — image / video uploads
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Razorpay — payment gateway (test keys for local dev)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Platform commission percent — what the marketplace takes from each order.
PLATFORM_COMMISSION_PERCENT=10

# CORS origin for the web app
WEB_ORIGIN="http://localhost:3000"

# Optional: Anthropic API key — unlocks AI page-block + theme generation.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"
