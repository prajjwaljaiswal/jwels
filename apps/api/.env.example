# Postgres connection string. In production use a pooled URL from Prisma Cloud /
# Supabase / Neon. In local dev, point at a docker-compose Postgres.
DATABASE_URL="postgresql://user:password@localhost:5432/jewel"

# JWT — sign auth tokens. Use 32+ random bytes (openssl rand -hex 32).
JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# Cloudinary — image / video uploads
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Razorpay — payment gateway (test keys for local dev)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Platform commission percent — what the marketplace takes from each order.
PLATFORM_COMMISSION_PERCENT=10

# CORS origins for the front-end apps. Also used to build links in support
# notification emails. Leave the allowlist empty to stay permissive in dev.
WEB_ORIGIN="http://localhost:3000"
VENDOR_ORIGIN="http://localhost:3001"
ADMIN_ORIGIN="http://localhost:3002"
STOREFRONT_ORIGIN="http://localhost:3003"

# ─── Mailgun (transactional email) ─────────────────────────────────────────────
# Primary transport for all lifecycle emails (welcome, orders, KYC, payouts, …).
# When MAILGUN_API_KEY / MAILGUN_DOMAIN are unset, emails are skipped silently
# (logged, never throws) so local dev / CI don't break.
MAILGUN_API_KEY=""                       # private API key from the Mailgun dashboard
MAILGUN_DOMAIN=""                        # sending domain, e.g. mg.vrindaonline.com (or a sandbox domain)
MAILGUN_FROM=""                          # From header, e.g. "Vrindaonline Marketplace <no-reply@mg.vrindaonline.com>"
# MAILGUN_URL="https://api.eu.mailgun.net" # EU-region domains only; default is US/global

# Optional: Anthropic API key — unlocks AI page-block + theme generation and
# AI-drafted support replies (falls back to a template when unset).
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ─── Multi-tenant storefront (see docs/deploy-multitenancy.md) ─────────────────
# Root registrable domain. Used to build the CNAME target (store.<APP_DOMAIN>) that
# vendors point a custom domain at. NOT the same as the storefront's
# NEXT_PUBLIC_APP_DOMAIN (which is the subdomain root, store.<APP_DOMAIN>).
APP_DOMAIN="vrindaonline.com"

# Shared secret guarding the storefront's POST /api/revalidate. MUST match the
# storefront's REVALIDATE_SECRET. Generate with: openssl rand -hex 32.
# Leave unset to disable on-demand revalidation (storefront falls back to TTL).
REVALIDATE_SECRET=""

# Comma-separated list of every storefront process URL to fan revalidation out to,
# one per process (e.g. http://127.0.0.1:3003 — add 3013,3023,… when scaling out).
STOREFRONT_INTERNAL_URLS="http://127.0.0.1:3003"

# Comma-separated public ingress IP(s) a vendor must point an APEX custom domain at
# via an A record (CNAME is illegal at the apex). Used by custom-domain verification.
INGRESS_IPS=""

# --- Support module (tickets + realtime chat) --------------------------------
# Where to email customer↔platform tickets that aren't routed to a vendor.
# If unset, only an explicitly-assigned admin (if any) is notified.
SUPPORT_NOTIFY_EMAIL=""
# Auto-close RESOLVED tickets after this many days of inactivity (default 7).
SUPPORT_AUTO_CLOSE_DAYS=7

# --- Marketing: Google Merchant Center (Merchant API v1) ---------------------
# Leave the account/data-source unset to disable the push (the feed + reconcile still
# work; product states stay PENDING). One-time setup (plan §5): registerGcp from a human
# admin account, add the service-account email as a Merchant Center user, and create a
# primary product data source of type API — then put its id below.
GOOGLE_MERCHANT_ACCOUNT_ID=""        # Merchant Center (MCA) account id
GOOGLE_MERCHANT_DATASOURCE_ID=""     # primary API product data source id
GOOGLE_MERCHANT_CONTENT_LANGUAGE="en"
GOOGLE_MERCHANT_FEED_LABEL="IN"
# Service-account credentials — set ONE of these (inline JSON wins if both set):
GOOGLE_MERCHANT_CREDENTIALS_JSON=""  # the service-account key JSON, inline
# GOOGLE_APPLICATION_CREDENTIALS=""  # ...or a path to the service-account key file
# Feed currency for the shopping feed (price suffix) — defaults to INR.
MARKETING_FEED_CURRENCY="INR"
