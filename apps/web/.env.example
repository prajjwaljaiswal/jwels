# Base URL of the backend API. Local dev points at `npm run dev:api`.
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Vendor dashboard origin (a separate app). After login/onboarding the seller is handed
# off here with their session. Dev: http://localhost:3001 (the default if unset).
# Prod: https://vendor.vrindaonline.com
NEXT_PUBLIC_VENDOR_URL="http://localhost:3001"
