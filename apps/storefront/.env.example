# Storefront (per-vendor branded shop). See docs/deploy-multitenancy.md.

# Backend API base URL — read on BOTH the server (RSC layout /brand fetch, middleware
# host resolution) and the client. In local dev pointed at http://localhost:4000.
NEXT_PUBLIC_API_URL="https://api.vrindaonline.com"

# Subdomain root for tenant storefronts: each vendor lives at {slug}.<this domain>.
# Keep it >= 3 labels so ONLY *.store.* hosts are treated as tenants (api./admin./etc.
# stay first-party). BAKED AT BUILD TIME — changing it needs a rebuild. A vendor adding
# or verifying a custom domain does NOT need a rebuild (that is DB + Caddy only).
NEXT_PUBLIC_APP_DOMAIN="store.vrindaonline.com"

# Auth token localStorage key (shared with the @jewel/lib api helper).
NEXT_PUBLIC_TOKEN_KEY="token"

# Sibling app URLs (used in links / footer).
NEXT_PUBLIC_WEB_URL="https://vrindaonline.com"
NEXT_PUBLIC_STOREFRONT_URL="https://store.vrindaonline.com"
NEXT_PUBLIC_ADMIN_URL="https://admin.vrindaonline.com"
NEXT_PUBLIC_VENDOR_URL="https://vendor.vrindaonline.com"

# Algolia — search-only public key (safe to expose to the browser).
NEXT_PUBLIC_ALGOLIA_APP_ID=""
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=""
NEXT_PUBLIC_ALGOLIA_INDEX="jewel_products"

# Shared secret guarding POST /api/revalidate (on-demand cache invalidation). MUST match
# the API's REVALIDATE_SECRET. Server-only — NO NEXT_PUBLIC_ prefix, never sent to the
# browser. Generate with: openssl rand -hex 32.
REVALIDATE_SECRET=""

# Scale-out only: enable a shared Redis cacheHandler when running >1 storefront process
# (see docs/deploy-multitenancy.md → Scaling out). Leave unset for a single process.
# REDIS_URL="redis://127.0.0.1:6379"
