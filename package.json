{
  "name": "jewel-marketplace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=api",
    "dev:web": "npm run dev --workspace=web",
    "dev:vendor": "npm run dev --workspace=vendor",
    "dev:admin": "npm run dev --workspace=admin",
    "db:migrate": "npm run prisma:migrate --workspace=api",
    "db:studio": "npm run prisma:studio --workspace=api",
    "build:web": "npm run build --workspace=web",
    "build:vendor": "npm run build --workspace=vendor",
    "build:admin": "npm run build --workspace=admin"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
