{
  "name": "jewel-marketplace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:vendor": "npm run dev --workspace=apps/vendor",
    "dev:admin": "npm run dev --workspace=apps/admin",
    "db:migrate": "npm run prisma:migrate --workspace=apps/api",
    "db:studio": "npm run prisma:studio --workspace=apps/api",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "build:vendor": "npm run build --workspace=apps/vendor",
    "build:admin": "npm run build --workspace=apps/admin",
    "build:all": "npm run build:api && npm run build:web && npm run build:vendor && npm run build:admin",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
